{
  "permissions": {
    "allow": [
      "Read"
    ],
    "deny": [
      "Read(.env)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./gradlew ktlintFormat 2>&1 | tail -3"
          }
        ]
      }
    ]
  }
}